# Optional. Copy to .env locally. Never commit real keys.

# Required only if you enable the OpenAI-compatible LLM relay.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Required only if you enable Anthropic relay mode.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Required only if you add a MiniMax adapter locally.
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.1
MINIMAX_FALLBACK_MODELS=MiniMax-M2.1,MiniMax-M2
MINIMAX_MAX_TOKENS=1400

# Optional public API key for Congress.gov.
CONGRESS_API_KEY=

# Optional app ports.
MNR_RELAY_PORT=8787
MNR_DATA_PORT=8790
MNR_PROVIDER_TIMEOUT=45
MNR_USER_AGENT=market-narrative-radar open-source research app contact@example.com
